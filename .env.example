# ============================================================
# 落石检测系统 — 环境变量配置模板
# ============================================================
# 使用方法: 复制为 .env 后修改对应值
#   cp .env.example .env
# Docker 部署时此文件会被 docker-compose 自动加载
# ============================================================

# ---- PushPlus 微信推送 ----
PUSHPLUS_TOKEN=your_token_here
PUSHPLUS_TOPIC=
LOCATION=钦州监测点

# ---- YOLO 检测参数 ----
DETECTION_CONFIDENCE=0.3
DETECTION_IMG_SIZE=640
ROCK_MODEL_PATH=models/rock_best.pt

# ---- 自适应跳帧 (三级: 基于运动显著性评分) ----
#   motion_score < 0.01 → SKIP_IDLE
#   0.01 ≤ score < 0.1  → SKIP_ACTIVE
#   score ≥ 0.1          → SKIP_CRITICAL
SKIP_IDLE=5
SKIP_ACTIVE=5
SKIP_CRITICAL=2
MOTION_SCORE_LOW=0.01
MOTION_SCORE_HIGH=0.1

# ---- MOG2 背景建模 ----
MOG2_HISTORY=500
MOG2_VAR_THRESHOLD=32
MOG2_DETECT_SHADOWS=false
MOG2_LEARNING_RATE=0.001
MOG2_MORPH_KERNEL=5
MOG2_RESET_IDLE_FRAMES=100
MOTION_MIN_AREA=100

# ---- 光照变化鲁棒性 ----
# 当帧间平均亮度突变超过阈值 (0-255) 时, 将学习率乘以 LIGHT_CHANGE_LR_FACTOR
# 防止云层/阳光变化导致 MOG2 背景模型被污染
LIGHT_CHANGE_THRESHOLD=15.0
LIGHT_CHANGE_LR_FACTOR=0.1
USE_CUDA_PREPROCESS=false

# ---- Sobel边缘增强 (苏国韶2025 / EENet Liu2026) ----
EDGE_ENHANCE_ENABLED=false
EDGE_ENHANCE_ALPHA=0.3
EDGE_ENHANCE_INTERVAL=1

# ---- 三帧差分运动滤波 (苏国韶2025) ----
TFD_ENABLED=false
TFD_IOU_THRESHOLD=0.30
TFD_MORPH_KERNEL=5
TFD_THRESHOLD=25

# ---- MOG2中心点运动滤波 (Zhang2024) ----
MOG2_FILTER_ENABLED=false

# ---- SAHI 切片辅助推理 (Slicing Aided Hyper Inference) ----
# 启用后对高分辨率帧分块推理, 适合远距离监控中目标像素过小的场景
# 切片有重叠并NMS合并, 避免边界截断漏检
SAHI_ENABLED=false
SAHI_SLICE_SIZE=640
SAHI_OVERLAP_RATIO=0.20
SAHI_MERGE_IOU=0.50

# ---- 概率融合 (YOLO置信度 + MOG2前景证据) ----
# 融合公式: P = P_YOLO * (1 - weight) + P_MOG2 * weight (加权平均)
FUSION_ENABLED=false
FUSION_MOTION_WEIGHT=0.50

# ---- 多帧时序确认 (预SORT闪烁抑制) ----
# 检测框必须在前后连续帧间有IoU匹配才送入SORT
# 过滤单帧闪烁假阳性, 与SORT的TRACK_MIN_CONFIRM互补
# IoU=0.20 偏低是为了兼容快速运动目标 (每帧位移可达自身尺寸 70%)
TEMPORAL_ENABLED=false
TEMPORAL_WINDOW=2
TEMPORAL_IOU=0.20

# ---- TensorRT 推理加速 ----
# 启用后优先加载 .engine 文件, 推理速度提升 2-3 倍
# 导出命令: python scripts/export_tensorrt.py
# 依赖: CUDA PyTorch + python -m pip install tensorrt
TENSORRT_ENABLED=false
# TENSORRT_MODEL_PATH=models/rock_best.engine

# ---- SORT 跟踪 ----
# min_confirm=3: 落石从出现到离开可能仅 3-5 帧, 5 帧确认会导致漏报
TRACK_MIN_CONFIRM=3
TRACK_MIN_AGE_FOR_ALERT=2
TRACK_MAX_MISSED=10
TRACK_IOU_THRESHOLD=0.3

# ---- 运动状态物理约束 (基准值, 以 25fps / 1080p 为参照) ----
# 运行时会根据实际 fps 和分辨率自动缩放:
#   速度阈值 ∝ 1/fps × height/1080 (低帧率 → 每帧位移大 → 阈值更高)
#   加速度阈值 ∝ 1/fps² × height/1080
FALLING_Y_ACCEL_THRESHOLD=7.5
FALLING_Y_SPEED_THRESHOLD=5.0

# ---- 预警分级 ----
ALERT_RED_CONFIDENCE=0.6
ALERT_RED_AREA_RATIO=0.02
ALERT_RED_MIN_AREA=5000
ALERT_YELLOW_CONFIDENCE=0.4
ALERT_YELLOW_AREA_RATIO=0.008
ALERT_YELLOW_MIN_AREA=2000
# 高度比阈值 (分辨率无关: bbox高度/画面高度, 解决不同分辨率下面积差异问题)
ALERT_RED_HEIGHT_RATIO=0.10
ALERT_YELLOW_HEIGHT_RATIO=0.05
ALERT_FALLING_MIN_CONF=0.3
ALERT_MULTI_COUNT=3
ALERT_MULTI_TOTAL_AREA_RATIO=0.01
ALERT_COOLDOWN_SECONDS=10

# ---- RTSP / 摄像头 ----
CAMERA_URL=
RTSP_TRANSPORT=tcp
# FFMPEG_EXTRA_OPTS=hwaccel|cuda    # H.265 硬解等额外 ffmpeg 选项
CAMERA_RECONNECT_BASE=5
CAMERA_RECONNECT_MAX=30
CAMERA_RECONNECT_BACKOFF=2.0
CAMERA_RECONNECT_MAX_ATTEMPTS=30

# ---- Web 服务 ----
WEB_HOST=127.0.0.1
WEB_PORT=8000
STREAM_TOKEN=
API_KEY=
IMAGE_URL_BASE=

# ---- MySQL 数据库 (可选, 不配置则使用 SQLite) ----
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=123456
# MYSQL_DATABASE=rock

# ---- 异步任务 / MJPEG ----
TASK_CLEANUP_SECONDS=3600
TASK_CLEANUP_STUCK_SECONDS=7200
VIDEO_TASK_WORKERS=2
PUSH_EXECUTOR_WORKERS=2
MJPEG_BLANK_WIDTH=640
MJPEG_BLANK_HEIGHT=360
MJPEG_FRAME_INTERVAL=0.05
